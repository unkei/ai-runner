        <!-- ==================== KEY PRINCIPLES BOX ==================== -->
        <mxCell id="principles" value="&lt;b&gt;Architectural Principles&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Pure functional state: (state, ...args) → newState&lt;br&gt;• Renderer &amp; logic fully separated — state.js has zero DOM/Canvas refs&lt;br&gt;• No event queue — input applied immediately via setInputX / setPlayerX&lt;br&gt;• 1 loop = 1 tick — full pipeline resolves in one tickGame() call&lt;br&gt;• All state is immutable; every update returns a new object" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffffcc;strokeColor=#d6d600;fontSize=11;size=15;align=left;" vertex="1" parent="1">
